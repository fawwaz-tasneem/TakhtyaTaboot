# Normalize line endings: keep LF in the repo, check out native on each OS.
* text=auto

# Force LF for code & data so cross-platform diffs stay clean.
*.cs   text eol=lf
*.xml  text eol=lf
*.md   text eol=lf
*.ps1  text eol=lf
*.py   text eol=lf

# Treat compiled mod binaries as binary if they ever get tracked.
*.dll  binary
*.pdb  binary
