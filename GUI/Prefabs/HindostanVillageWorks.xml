<Prefab>
  <Window>

    <!-- Dim full-screen backdrop -->
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="BlankWhiteSquare_9" Color="#000000ff" AlphaFactor="0.65">
      <Children>

        <!-- Centered panel -->
        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="1040" SuggestedHeight="780" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Children>

            <!-- Canvas background -->
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="StdAssets\Popup\canvas" />

            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Top" MarginTop="24" MarginLeft="28" MarginRight="28" StackLayout.LayoutMethod="VerticalBottomToTop">
              <Children>

                <!-- Title -->
                <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="44" Brush="Popup.Title.Text" Brush.FontSize="36" HorizontalAlignment="Center" Text="@TitleText" />

                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="20" Sprite="StdAssets\Popup\divider" IsEnabled="false" />

                <!-- District numbers -->
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="26" MarginTop="4" Brush="Popup.Description.Text" Brush.FontSize="18" HorizontalAlignment="Center" Text="@StatsLine" />

                <!-- Coffer + collect -->
                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="40" MarginTop="2" StackLayout.LayoutMethod="HorizontalLeftToRight">
                  <Children>
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Brush="Popup.Description.Text" Brush.FontSize="20" VerticalAlignment="Center" Text="@CofferLine" />
                    <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="200" SuggestedHeight="36" VerticalAlignment="Center" Brush="Popup.SelectionElement.Tuple" IsEnabled="@CanCollect" Command.Click="ExecuteCollect" UpdateChildrenStates="true">
                      <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Brush="Popup.Tuple.Text" Brush.FontSize="20" Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center" Text="Collect the coffer" IsDisabled="true" />
                      </Children>
                    </ButtonWidget>
                  </Children>
                </ListPanel>

                <!-- The work under way: line + progress bar -->
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="28" MarginTop="6" Brush="Popup.Tuple.Text" Brush.FontSize="21" Text="@ActiveLine" />
                <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="424" SuggestedHeight="14" HorizontalAlignment="Left" MarginTop="2" Sprite="BlankWhiteSquare_9" Color="#2A2118FF" IsVisible="@HasActive">
                  <Children>
                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="@BarWidth" SuggestedHeight="10" HorizontalAlignment="Left" VerticalAlignment="Center" MarginLeft="2" Sprite="BlankWhiteSquare_9" Color="#A98948FF" />
                  </Children>
                </Widget>
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="24" Brush="Popup.Description.Text" Brush.FontSize="17" Text="@QueuedLine" IsVisible="@HasQueued" />
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="24" Brush="Popup.Description.Text" Brush.FontSize="17" Text="@BuiltLine" />

                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="16" MarginTop="2" Sprite="StdAssets\Popup\divider" IsEnabled="false" />

                <!-- The ledger of buildable works -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="418" MarginTop="4" Sprite="scrollable_field_9">
                  <Children>
                    <ScrollablePanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" MarginTop="10" MarginBottom="10" MarginLeft="8" MarginRight="8" AutoHideScrollBars="true" ClipRect="WorksClip" InnerPanel="WorksClip\WorksList" VerticalScrollbar="..\WorksScrollbar">
                      <Children>
                        <Widget Id="WorksClip" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" ClipContents="true">
                          <Children>
                            <ListPanel Id="WorksList" DataSource="{Projects}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="VerticalBottomToTop">
                              <ItemTemplate>
                                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="76" MarginBottom="4" Sprite="BlankWhiteSquare_9" Color="#FFFFFFFF" AlphaFactor="0.05">
                                  <Children>
                                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" StackLayout.LayoutMethod="HorizontalLeftToRight">
                                      <Children>

                                        <!-- Name / cost / effect -->
                                        <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" MarginLeft="12" StackLayout.LayoutMethod="VerticalBottomToTop">
                                          <Children>
                                            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="26" StackLayout.LayoutMethod="HorizontalLeftToRight">
                                              <Children>
                                                <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="StretchToParent" Brush="Popup.Tuple.Text" Brush.FontSize="22" Text="@Name" />
                                                <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="StretchToParent" MarginLeft="16" Brush="Popup.Description.Text" Brush.FontSize="17" Text="@CostLine" />
                                                <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="StretchToParent" MarginLeft="16" Brush="Popup.Title.Text" Brush.FontSize="17" Text="@StatusText" IsVisible="@ShowStatus" />
                                              </Children>
                                            </ListPanel>
                                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="22" Brush="Popup.Description.Text" Brush.FontSize="16" ClipContents="true" Text="@Effect" />
                                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="20" Brush="Popup.Description.Text" Brush.FontSize="14" ClipContents="true" Text="@Hint" />
                                          </Children>
                                        </ListPanel>

                                        <!-- Begin / Queue -->
                                        <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="130" SuggestedHeight="40" VerticalAlignment="Center" MarginRight="14" Brush="Popup.SelectionElement.Tuple" IsEnabled="@CanAct" IsVisible="@ShowAct" Command.Click="ExecuteAct" UpdateChildrenStates="true">
                                          <Children>
                                            <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Brush="Popup.Tuple.Text" Brush.FontSize="20" Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center" Text="@ActLabel" IsDisabled="true" />
                                          </Children>
                                        </ButtonWidget>

                                      </Children>
                                    </ListPanel>
                                  </Children>
                                </Widget>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>
                    <ScrollbarWidget Id="WorksScrollbar" WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="8" HorizontalAlignment="Right" VerticalAlignment="Top" MarginRight="2" MarginTop="12" MarginBottom="12" AlignmentAxis="Vertical" Handle="WorksScrollbarHandle" MaxValue="100" MinValue="0">
                      <Children>
                        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="4" HorizontalAlignment="Center" Sprite="BlankWhiteSquare_9" Color="#5A4033FF" AlphaFactor="0.5" />
                        <ImageWidget Id="WorksScrollbarHandle" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedHeight="10" SuggestedWidth="10" HorizontalAlignment="Center" Brush="FaceGen.Scrollbar.Handle" />
                      </Children>
                    </ScrollbarWidget>
                  </Children>
                </Widget>

                <!-- Footer hint -->
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="28" MarginTop="6" Brush="Popup.Description.Text" Brush.FontSize="17" HorizontalAlignment="Center" Text="A village holds one work under construction; one more may wait in the queue." />

              </Children>
            </ListPanel>

            <!-- Frame border -->
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="frame_9" ExtendLeft="18" ExtendTop="18" ExtendRight="18" ExtendBottom="18" IsEnabled="false" />

            <!-- Close button (top-right) -->
            <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="48" SuggestedHeight="48" HorizontalAlignment="Right" VerticalAlignment="Top" MarginTop="18" MarginRight="18" Brush="Popup.CloseButton" Command.Click="ExecuteClose" />

          </Children>
        </Widget>

      </Children>
    </Widget>

  </Window>
</Prefab>
